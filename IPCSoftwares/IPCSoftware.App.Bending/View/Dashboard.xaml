<UserControl x:Class="IPCSoftware.App.Bending.Views.BendingUat2View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BendingMachine.Views"
             mc:Ignorable="d" 
             d:DesignHeight="1050" d:DesignWidth="1700" Background="#F4F7F9"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <SolidColorBrush x:Key="MainBlue" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="OkGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="NgRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="BgLight" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="LineGray" Color="#CBD5E1"/>
    </UserControl.Resources>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Canvas Width="950" Height="700">

            <Border Canvas.Left="20" Canvas.Top="230" Width="100" Height="100" BorderBrush="{StaticResource AccentBlue}" BorderThickness="3" CornerRadius="8" Background="#F1F5F9">
                <TextBlock Text="🤖" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Canvas.Left="40" Canvas.Top="335" Text="ROBOT 1" FontWeight="Bold" FontSize="12" Foreground="{StaticResource AccentBlue}"/>

            <Path Data="M 70,330 C 70,450 150,540 255,575" Stroke="{StaticResource OkGreen}" StrokeThickness="8" StrokeDashArray="4 2" Opacity="0.8"/>

            <!--<Ellipse Canvas.Left="190" Canvas.Top="150" Width="280" Height="280" Stroke="#E2E8F0" StrokeThickness="8" StrokeDashArray="4 2"/>-->
            <Border Canvas.Left="220" Canvas.Top="180" Width="220" Height="220" CornerRadius="110" Background="White" BorderBrush="{StaticResource MainBlue}" BorderThickness="8">
                <Canvas>
                    <Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="100" Canvas.Top="10"/>
                    <Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="100" Canvas.Top="175"/>
                    <Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="10" Canvas.Top="100"/>
                    <Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="175" Canvas.Top="100"/>
                </Canvas>
            </Border>
            <TextBlock Canvas.Left="275" Canvas.Top="410" Text="TURN TABLE 1" FontWeight="Bold" FontSize="12" Foreground="{StaticResource MainBlue}"/>

            <Border Canvas.Left="255" Canvas.Top="445" Width="150" Height="80" Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="12">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="INSPECTION AREA" FontSize="10" FontWeight="Black" Foreground="#B45309" HorizontalAlignment="Center"/>
                    <TextBlock Text="QR Read | CCD" FontSize="9" FontWeight="SemiBold" Foreground="#D97706" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Path Data="M 330,430 L 330,445" Stroke="{StaticResource LineGray}" StrokeThickness="2" StrokeDashArray="2 2"/>

            <Border Canvas.Left="255" Canvas.Top="540" Width="150" Height="70" BorderBrush="#CBD5E1" BorderThickness="2" CornerRadius="12" Background="{StaticResource BgLight}">
                <TextBlock Text="INPUT TRAY" FontSize="10" FontWeight="Black" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Path Data="M 330,525 L 330,540" Stroke="{StaticResource LineGray}" StrokeThickness="2" StrokeDashArray="2 2"/>

            <Ellipse Canvas.Left="475" Canvas.Top="260" Width="20" Height="20" Fill="#93C5FD" Stroke="#2563EB" StrokeThickness="2"/>

            <!--<Ellipse Canvas.Left="510" Canvas.Top="150" Width="280" Height="280" Stroke="#E2E8F0" StrokeThickness="8" StrokeDashArray="4 2"/>-->
            <Border Canvas.Left="540" Canvas.Top="180" Width="220" Height="220" CornerRadius="110" Background="White" BorderBrush="{StaticResource OkGreen}" BorderThickness="8">
                <Canvas>
                    <Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="100" Canvas.Top="10"/>
                    <Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="100" Canvas.Top="175"/>
                    <Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="10" Canvas.Top="100"/>
                    <Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="180" Canvas.Top="100"/>
                </Canvas>
            </Border>
            <TextBlock Canvas.Left="595" Canvas.Top="410" Text="TURN TABLE 2" FontWeight="Bold" FontSize="12" Foreground="{StaticResource OkGreen}"/>

            <Border Canvas.Left="800" Canvas.Top="230" Width="100" Height="100" BorderBrush="{StaticResource AccentBlue}" BorderThickness="3" CornerRadius="8" Background="#F1F5F9">
                <TextBlock Text="🤖" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Canvas.Left="820" Canvas.Top="335" Text="ROBOT 2" FontWeight="Bold" FontSize="12" Foreground="{StaticResource AccentBlue}"/>

            <Path Data="M 850,330 C 850,450 750,540 650,575" Stroke="{StaticResource OkGreen}" StrokeThickness="8" StrokeDashArray="4 2"/>

            <Border Canvas.Left="575" Canvas.Top="445" Width="150" Height="80" Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="12">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="INSPECTION AREA" FontSize="10" FontWeight="Black" Foreground="#B45309" HorizontalAlignment="Center"/>
                    <TextBlock Text="QR Read | CCD" FontSize="9" FontWeight="SemiBold" Foreground="#D97706" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Path Data="M 650,430 L 650,445" Stroke="{StaticResource LineGray}" StrokeThickness="2" StrokeDashArray="2 2"/>

            <Border Canvas.Left="575" Canvas.Top="540" Width="150" Height="80" Background="#F0FDF4" BorderBrush="{StaticResource OkGreen}" BorderThickness="2" CornerRadius="12">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="OUTPUT TRAY" FontSize="10" FontWeight="Black" Foreground="{StaticResource OkGreen}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Film &amp; Flip" FontSize="9" FontWeight="SemiBold" Foreground="#059669" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Path Data="M 650,525 L 650,540" Stroke="{StaticResource LineGray}" StrokeThickness="2" StrokeDashArray="2 2"/>

        </Canvas>
    </Grid>
</UserControl>