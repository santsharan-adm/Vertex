<Window x:Class="IPCSoftware.App.Bending.Views.BendingUat2View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Industrial Bending Machine" Height="1050" Width="1700" Background="#F4F7F9"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

	<Window.Resources>
		<SolidColorBrush x:Key="MainBlue" Color="#1E293B"/>
		<SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
		<SolidColorBrush x:Key="OkGreen" Color="#10B981"/>
		<SolidColorBrush x:Key="NgRed" Color="#EF4444"/>
		<SolidColorBrush x:Key="CardWhite" Color="#FFFFFF"/>
		<SolidColorBrush x:Key="BgLight" Color="#F8FAFC"/>
		<SolidColorBrush x:Key="LineGray" Color="#CBD5E1"/>
		<DropShadowEffect x:Key="CardShadow" BlurRadius="20" Opacity="0.08" ShadowDepth="4" Color="#0F172A" Direction="270"/>

		<Style x:Key="MachineCard" TargetType="Border">
			<Setter Property="Background" Value="{StaticResource CardWhite}"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Effect" Value="{StaticResource CardShadow}"/>
			<Setter Property="Margin" Value="10"/>
		</Style>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="75"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="40"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="{StaticResource MainBlue}">
			<Grid Margin="30,0">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<Ellipse Width="35" Height="35" Fill="{StaticResource AccentBlue}" Margin="0,0,15,0"/>
					<StackPanel>
						<TextBlock Text="BENDING MACHINE" Foreground="White" FontSize="20" FontWeight="Black"/>
						<TextBlock Text="CELL UNIT: PRO_BEND_01 | OPERATOR: ADMIN" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
					</StackPanel>
				</StackPanel>
				<Border Background="#059669" CornerRadius="15" Padding="15,6" HorizontalAlignment="Right" VerticalAlignment="Center">
					<TextBlock Text="● SYSTEM ACTIVE" Foreground="White" FontSize="12" FontWeight="Bold"/>
				</Border>
			</Grid>
		</Border>

		<UniformGrid Grid.Row="1" Columns="4" Margin="15,10,15,5">
			<Border Background="#0B1120" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="10" Margin="6" Effect="{StaticResource CardShadow}">
				<StackPanel>
					<TextBlock Text="TT-1 Pos-1" Foreground="#93C5FD" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
					<UniformGrid Columns="2">
						<StackPanel>
							<TextBlock Text="T1: —°C" Foreground="White"/>
							<TextBlock Text="T2: —°C" Foreground="White"/>
						</StackPanel>
						<StackPanel>
							<TextBlock Text="P1: —N" Foreground="White"/>
							<TextBlock Text="P2: —N" Foreground="White"/>
						</StackPanel>
					</UniformGrid>
				</StackPanel>
			</Border>
			<Border Background="#0B1120" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="10" Margin="6">
				<StackPanel>
					<TextBlock Text="TT-1 Pos-2" Foreground="#93C5FD" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
					<UniformGrid Columns="2">
						<StackPanel>
							<TextBlock Text="T3: —°C" Foreground="White"/>
							<TextBlock Text="T4: —°C" Foreground="White"/>
						</StackPanel>
						<StackPanel>
							<TextBlock Text="P3: —N" Foreground="White"/>
							<TextBlock Text="P4: —N" Foreground="White"/>
						</StackPanel>
					</UniformGrid>
				</StackPanel>
			</Border>
			<Border Background="#0B1120" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="10" Margin="6">
				<StackPanel>
					<TextBlock Text="TT-2 Pos-1" Foreground="#93C5FD" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
					<UniformGrid Columns="2">
						<StackPanel>
							<TextBlock Text="T1: —°C" Foreground="White"/>
							<TextBlock Text="T2: —°C" Foreground="White"/>
						</StackPanel>
						<StackPanel>
							<TextBlock Text="P1: —N" Foreground="White"/>
							<TextBlock Text="P2: —N" Foreground="White"/>
						</StackPanel>
					</UniformGrid>
				</StackPanel>
			</Border>
			<Border Background="#0B1120" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="10" Margin="6">
				<StackPanel>
					<TextBlock Text="TT-2 Pos-2" Foreground="#93C5FD" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
					<UniformGrid Columns="2">
						<StackPanel>
							<TextBlock Text="T3: —°C" Foreground="White"/>
							<TextBlock Text="T4: —°C" Foreground="White"/>
						</StackPanel>
						<StackPanel>
							<TextBlock Text="P3: —N" Foreground="White"/>
							<TextBlock Text="P4: —N" Foreground="White"/>
						</StackPanel>
					</UniformGrid>
				</StackPanel>
			</Border>
		</UniformGrid>

		<Grid Grid.Row="2" Margin="10,0,10,10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="300"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="420"/>
			</Grid.ColumnDefinitions>

			<StackPanel Grid.Column="0">
				<Border Style="{StaticResource MachineCard}" Padding="15">
					<StackPanel>
						<TextBlock Text="FINAL INSPECTION (XYZQ)" FontWeight="Black" Foreground="{StaticResource MainBlue}" FontSize="14" Margin="0,0,0,10"/>
						<Border Background="{StaticResource BgLight}" Padding="15" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="2">
							<UniformGrid Columns="2" Rows="2">
								<StackPanel Margin="0,0,0,10">
									<TextBlock Text="X Axis" FontSize="11" Foreground="#64748B" FontWeight="Bold"/>
									<TextBlock Text="120.45" FontWeight="Black" FontSize="18" Foreground="{StaticResource MainBlue}"/>
								</StackPanel>
								<StackPanel Margin="0,0,0,10">
									<TextBlock Text="Y Axis" FontSize="11" Foreground="#64748B" FontWeight="Bold"/>
									<TextBlock Text="85.12" FontWeight="Black" FontSize="18" Foreground="{StaticResource MainBlue}"/>
								</StackPanel>
								<StackPanel>
									<TextBlock Text="Z Axis" FontSize="11" Foreground="#64748B" FontWeight="Bold"/>
									<TextBlock Text="15.70" FontWeight="Black" FontSize="18" Foreground="{StaticResource MainBlue}"/>
								</StackPanel>
								<StackPanel>
									<TextBlock Text="Status (Q)" FontSize="11" Foreground="#64748B" FontWeight="Bold"/>
									<TextBlock Text="PASS" Foreground="{StaticResource OkGreen}" FontWeight="Black" FontSize="18"/>
								</StackPanel>
							</UniformGrid>
						</Border>
					</StackPanel>
				</Border>
				<Border Style="{StaticResource MachineCard}" Padding="15">
					<StackPanel>
						<TextBlock Text="SYSTEM METRICS" FontWeight="Black" Foreground="{StaticResource MainBlue}" FontSize="14" Margin="0,0,0,10"/>
						<Border Background="#3B82F6" CornerRadius="8" Margin="0,0,0,6" Padding="8">
							<StackPanel>
								<TextBlock Text="HEATER TEMP" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
								<TextBlock Text="185.5°C" Foreground="White" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>
						<Border Background="{StaticResource OkGreen}" CornerRadius="8" Margin="0,0,0,6" Padding="8">
							<TextBlock Text="TOTAL OK" Foreground="White" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
						</Border>
						<Border Background="{StaticResource NgRed}" CornerRadius="8" Padding="8">
							<TextBlock Text="TOTAL NG" Foreground="White" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
						</Border>
					</StackPanel>
				</Border>
			</StackPanel>

			<Border Grid.Column="1" Style="{StaticResource MachineCard}" ClipToBounds="True">
				<Canvas Width="900" Height="750" HorizontalAlignment="Center" VerticalAlignment="Center">

					<Border Canvas.Left="40" Canvas.Top="280" Width="100" Height="100" BorderBrush="{StaticResource AccentBlue}" BorderThickness="3" CornerRadius="8" Background="#F1F5F9">
						<TextBlock Text="🤖" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
					<TextBlock Canvas.Left="55" Canvas.Top="385" Text="ROBOT 1" FontWeight="Bold" FontSize="12" Foreground="{StaticResource AccentBlue}"/>

					<Path Data="M 90,380 C 90,500 150,590 255,625" Stroke="{StaticResource OkGreen}" StrokeThickness="3" StrokeDashArray="4 2" Opacity="0.8"/>

					<Ellipse Canvas.Left="190" Canvas.Top="200" Width="280" Height="280" Stroke="#E2E8F0" StrokeThickness="3" StrokeDashArray="4 2"/>
					<Border Canvas.Left="220" Canvas.Top="230" Width="220" Height="220" CornerRadius="110" Background="White" BorderBrush="{StaticResource MainBlue}" BorderThickness="4">
						<Canvas>
							<Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="100" Canvas.Top="10"/>
							<Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="100" Canvas.Top="190"/>
							<Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="10" Canvas.Top="100"/>
							<Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="190" Canvas.Top="100"/>
						</Canvas>
					</Border>
					<TextBlock Canvas.Left="275" Canvas.Top="460" Text="TURN TABLE 1" FontWeight="Bold" FontSize="12" Foreground="{StaticResource MainBlue}"/>

					<Border Canvas.Left="255" Canvas.Top="495" Width="150" Height="80" Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="12">
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="INSPECTION AREA" FontSize="10" FontWeight="Black" Foreground="#B45309" HorizontalAlignment="Center"/>
							<TextBlock Text="QR Read | CCD" FontSize="9" FontWeight="SemiBold" Foreground="#D97706" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<Path Data="M 330,480 L 330,495" Stroke="{StaticResource LineGray}" StrokeThickness="2" StrokeDashArray="2 2"/>
					<Border Canvas.Left="255" Canvas.Top="590" Width="150" Height="70" BorderBrush="#CBD5E1" BorderThickness="2" CornerRadius="12" Background="{StaticResource BgLight}">
						<TextBlock Text="INPUT TRAY" FontSize="10" FontWeight="Black" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
					<Path Data="M 330,575 L 330,590" Stroke="{StaticResource LineGray}" StrokeThickness="2" StrokeDashArray="2 2"/>

					<Ellipse Canvas.Left="475" Canvas.Top="310" Width="20" Height="20" Fill="#93C5FD" Stroke="#2563EB" StrokeThickness="2"/>

					<Ellipse Canvas.Left="510" Canvas.Top="200" Width="280" Height="280" Stroke="#E2E8F0" StrokeThickness="3" StrokeDashArray="4 2"/>
					<Border Canvas.Left="540" Canvas.Top="230" Width="220" Height="220" CornerRadius="110" Background="White" BorderBrush="{StaticResource OkGreen}" BorderThickness="4">
						<Canvas>
							<Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="100" Canvas.Top="10"/>
							<Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="100" Canvas.Top="190"/>
							<Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="10" Canvas.Top="100"/>
							<Ellipse Width="20" Height="20" Fill="#93C5FD" Canvas.Left="190" Canvas.Top="100"/>
						</Canvas>
					</Border>
					<TextBlock Canvas.Left="595" Canvas.Top="460" Text="TURN TABLE 2" FontWeight="Bold" FontSize="12" Foreground="{StaticResource OkGreen}"/>

					<Border Canvas.Left="575" Canvas.Top="495" Width="150" Height="80" Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="12">
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="INSPECTION AREA" FontSize="10" FontWeight="Black" Foreground="#B45309" HorizontalAlignment="Center"/>
							<TextBlock Text="QR Read | CCD" FontSize="9" FontWeight="SemiBold" Foreground="#D97706" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<Path Data="M 650,480 L 650,495" Stroke="{StaticResource LineGray}" StrokeThickness="2" StrokeDashArray="2 2"/>
					<Border Canvas.Left="575" Canvas.Top="590" Width="150" Height="80" Background="#F0FDF4" BorderBrush="{StaticResource OkGreen}" BorderThickness="2" CornerRadius="12">
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="OUTPUT TRAY" FontSize="10" FontWeight="Black" Foreground="{StaticResource OkGreen}" HorizontalAlignment="Center"/>
							<TextBlock Text="Film &amp; Flip" FontSize="9" FontWeight="SemiBold" Foreground="#059669" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<Path Data="M 650,575 L 650,590" Stroke="{StaticResource LineGray}" StrokeThickness="2" StrokeDashArray="2 2"/>

					<Canvas Canvas.Left="800" Canvas.Top="250">
						<Path Data="M 90,80 L 60,20 L 0,60" Stroke="#94A3B8" StrokeThickness="4" StrokeLineJoin="Round" StrokeStartLineCap="Round"/>
						<TextBlock Text="ROBO 2" FontWeight="Black" FontSize="10" Foreground="#64748B" Canvas.Left="60" Canvas.Top="100"/>
					</Canvas>

				</Canvas>
			</Border>

			<StackPanel Grid.Column="2">
				<Border Style="{StaticResource MachineCard}" Padding="20" Height="490">
					<UniformGrid Columns="2" Rows="2">
						<Border BorderBrush="#E2E8F0" BorderThickness="2" Margin="6" Background="#0F172A" CornerRadius="8" Height="180">
							<TextBlock Text="CAM 1" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<Border BorderBrush="#E2E8F0" BorderThickness="2" Margin="6" Background="#0F172A" CornerRadius="8" Height="180">
							<TextBlock Text="CAM 2" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<Border BorderBrush="#E2E8F0" BorderThickness="2" Margin="6" Background="#0F172A" CornerRadius="8" Height="180">
							<TextBlock Text="CAM 3" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<Border BorderBrush="#E2E8F0" BorderThickness="2" Margin="6" Background="#0F172A" CornerRadius="8" Height="180">
							<TextBlock Text="CAM 4" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</UniformGrid>
				</Border>
				<Border Style="{StaticResource MachineCard}" Padding="20">
					<StackPanel>
						<TextBlock Text="QR CODE" FontWeight="Black" FontSize="14" Margin="0,0,0,10"/>
						<Border Width="110" Height="110" Background="{StaticResource BgLight}" BorderBrush="#CBD5E1" BorderThickness="2" CornerRadius="10">
							<TextBlock Text="[SCAN QR]" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</StackPanel>
				</Border>
			</StackPanel>
		</Grid>

		<Border Grid.Row="3" Background="{StaticResource MainBlue}">
			<Grid Margin="30,0">
				<TextBlock Text="PLC CONNECTED" Foreground="#94A3B8" VerticalAlignment="Center"/>
				<TextBlock Text="31-Mar-2026 | 12:44" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
			</Grid>
		</Border>
	</Grid>
</Window>