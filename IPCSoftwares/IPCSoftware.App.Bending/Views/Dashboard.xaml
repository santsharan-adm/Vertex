                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Part No." Foreground="White" FontSize="8.5" FontWeight="Bold"/>
                            <TextBlock Text="Temp (C)" Foreground="White" FontSize="8.5" FontWeight="Bold" Grid.Column="1" HorizontalAlignment="Center"/>
                            <TextBlock Text="Load (Newton)" Foreground="White" FontSize="8.5" FontWeight="Bold" Grid.Column="2" HorizontalAlignment="Right"/>
