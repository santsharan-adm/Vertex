                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                </StackPanel>
                            </Grid>
