                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="CYCLE TIME: 12.4s" Foreground="White" FontWeight="Bold" Margin="0,0,20,0"/>
                    <TextBlock Text="EFFICIENCY: 94%" Foreground="{StaticResource OkGreen}" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="#1E293B" CornerRadius="8" Padding="5" Margin="0" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1.5">
