<UserControl x:Class="IPCSoftware.App.Bending.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600" Background="#F1F5F9">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBorder" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="OkGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="NgRed" Color="#EF4444"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Row="1" Grid.Column="1" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Canvas Width="750" Height="450" Background="Transparent">

                <Border Canvas.Left="20" Canvas.Top="20" Width="60" Height="60" BorderBrush="{StaticResource NgRed}" BorderThickness="1.5" CornerRadius="8" Background="#FFF1F2">
                    <TextBlock Text="❌" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource NgRed}"/>
                </Border>

                <Border Canvas.Left="20" Canvas.Top="140" Width="60" Height="60" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1.5" CornerRadius="8" Background="White">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🤖" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Robot1Name}" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Canvas Canvas.Left="130" Canvas.Top="60">
                    <Border Width="140" Height="140" CornerRadius="70" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="3.5">
                        <Canvas>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource AccentBlue}" Canvas.Left="62.5" Canvas.Top="10"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource AccentBlue}" Canvas.Left="62.5" Canvas.Top="115"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource AccentBlue}" Canvas.Left="10" Canvas.Top="62.5"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource AccentBlue}" Canvas.Left="115" Canvas.Top="62.5"/>
                        </Canvas>
                    </Border>
                    <TextBlock Canvas.Left="35" Canvas.Top="145" Text="TURN TABLE 1" FontWeight="Bold" FontSize="10" Foreground="{StaticResource PanelBorder}"/>
                </Canvas>

                <Polyline Points="270,130 310,130 310,125" Stroke="{StaticResource PanelBorder}" StrokeThickness="2.5"/>
                <Border Canvas.Left="290" Canvas.Top="90" Width="35" Height="35" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="2" CornerRadius="4">
                    <TextBlock Text="🔄" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" Opacity="0.5"/>
                </Border>

                <Canvas Canvas.Left="360" Canvas.Top="60">
                    <Border Width="140" Height="140" CornerRadius="70" Background="White" BorderBrush="{StaticResource OkGreen}" BorderThickness="3.5">
                        <Canvas>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource OkGreen}" Canvas.Left="62.5" Canvas.Top="10"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource OkGreen}" Canvas.Left="62.5" Canvas.Top="115"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource OkGreen}" Canvas.Left="10" Canvas.Top="62.5"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource OkGreen}" Canvas.Left="115" Canvas.Top="62.5"/>
                        </Canvas>
                    </Border>
                    <TextBlock Canvas.Left="35" Canvas.Top="145" Text="TURN TABLE 2" FontWeight="Bold" FontSize="10" Foreground="{StaticResource OkGreen}"/>
                </Canvas>

                <Border Canvas.Left="580" Canvas.Top="140" Width="60" Height="60" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1.5" CornerRadius="8" Background="White">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🤖" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Robot2Name}" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Canvas.Left="580" Canvas.Top="20" Width="60" Height="60" BorderBrush="{StaticResource NgRed}" BorderThickness="1.5" CornerRadius="8" Background="#FFF1F2">
                    <TextBlock Text="❌" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource NgRed}"/>
                </Border>

                <Polyline Points="50,200 50,300 150,300" Stroke="{StaticResource PanelBorder}" StrokeThickness="2.5" Opacity="0.4"/>
                <Polyline Points="610,200 610,300 480,300" Stroke="{StaticResource PanelBorder}" StrokeThickness="2.5" Opacity="0.4"/>
            </Canvas>
        </Viewbox>

    </Grid>
</UserControl>