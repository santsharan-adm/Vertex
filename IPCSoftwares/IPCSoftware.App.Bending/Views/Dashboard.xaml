<UserControl x:Class="IPCSoftware.App.Bending.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600" Background="#F1F5F9">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBorder" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="OkGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="NgRed" Color="#EF4444"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="#1E293B" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="FLEX BENDING MACHINE" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#10B981" Margin="20,0,0,0" Padding="8,2" CornerRadius="4" VerticalAlignment="Center">
                        <TextBlock Text="RUNNING" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="CYCLE TIME: 12.4s" Foreground="White" FontWeight="Bold" Margin="0,0,20,0"/>
                    <TextBlock Text="EFFICIENCY: 94%" Foreground="#10B981" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="CONTROLS" FontWeight="Bold" FontSize="12" Margin="0,0,0,10" Foreground="#64748B"/>
            <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#CBD5E1" BorderThickness="1">
                <StackPanel>
                    <UniformGrid Columns="2">
                        <Button Content="START" Margin="2" Padding="5" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="PAUSE" Margin="2" Padding="5" Background="#F59E0B" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    </UniformGrid>
                    <Button Content="NEXT STAGE" Margin="2,5,2,2" Padding="5" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </Border>
            <TextBlock Text="EVENT LOG" FontWeight="Bold" FontSize="12" Margin="0,10,0,5" Foreground="#64748B"/>
            <Border Background="White" Height="200" CornerRadius="5" BorderBrush="#CBD5E1" BorderThickness="1">
                <TextBox BorderThickness="0" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                         Text="21:58:26 — Tray present &amp; aligned&#x0a;21:58:30 — Robot 1 picking..." FontSize="10" Padding="5"/>
            </Border>
        </StackPanel>

        <Viewbox Grid.Row="1" Grid.Column="1" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Canvas Width="700" Height="450" Background="Transparent">

                <Border Canvas.Left="10" Canvas.Top="20" Width="60" Height="60" BorderBrush="{StaticResource NgRed}" BorderThickness="1.5" CornerRadius="8" Background="#FFF1F2">
                    <TextBlock Text="❌" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource NgRed}"/>
                </Border>
                <TextBlock Canvas.Left="30" Canvas.Top="85" Text="NG" FontWeight="Bold" FontSize="12" Foreground="{StaticResource NgRed}"/>

                <Border Canvas.Left="10" Canvas.Top="140" Width="60" Height="60" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1.5" CornerRadius="8" Background="White">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🤖" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="ROBOT 1" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Canvas Canvas.Left="110" Canvas.Top="60">
                    <Border Width="140" Height="140" CornerRadius="70" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="3.5">
                        <Canvas>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource AccentBlue}" Canvas.Left="62.5" Canvas.Top="10"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource AccentBlue}" Canvas.Left="62.5" Canvas.Top="115"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource AccentBlue}" Canvas.Left="10" Canvas.Top="62.5"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource AccentBlue}" Canvas.Left="115" Canvas.Top="62.5"/>
                        </Canvas>
                    </Border>
                    <TextBlock Canvas.Left="35" Canvas.Top="145" Text="TURN TABLE 1" FontWeight="Bold" FontSize="10" Foreground="{StaticResource PanelBorder}"/>
                    <Border Canvas.Left="20" Canvas.Top="165" Width="100" Height="45" Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="1.2" CornerRadius="5">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="INSPECTION" FontSize="9" FontWeight="Black" HorizontalAlignment="Center"/>
                            <TextBlock Text="QR | CCD" FontSize="7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Canvas.Left="20" Canvas.Top="215" Width="100" Height="45" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1.2" CornerRadius="5" Background="White">
                        <TextBlock Text="INPUT TRAY" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Canvas>

                <Polyline Points="40,200 40,275 130,275" Stroke="{StaticResource PanelBorder}" StrokeThickness="2"/>

                <Polyline Points="250,130 290,130 290,125" Stroke="{StaticResource PanelBorder}" StrokeThickness="2.5"/>
                <Border Canvas.Left="272" Canvas.Top="90" Width="35" Height="35" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="2" CornerRadius="4">
                    <TextBlock Text="🔄" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" Opacity="0.5"/>
                </Border>

                <Canvas Canvas.Left="330" Canvas.Top="60">
                    <Border Width="140" Height="140" CornerRadius="70" Background="White" BorderBrush="{StaticResource OkGreen}" BorderThickness="3.5">
                        <Canvas>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource OkGreen}" Canvas.Left="62.5" Canvas.Top="10"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource OkGreen}" Canvas.Left="62.5" Canvas.Top="115"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource OkGreen}" Canvas.Left="10" Canvas.Top="62.5"/>
                            <Ellipse Width="15" Height="15" Fill="{StaticResource OkGreen}" Canvas.Left="115" Canvas.Top="62.5"/>
                        </Canvas>
                    </Border>
                    <TextBlock Canvas.Left="35" Canvas.Top="145" Text="TURN TABLE 2" FontWeight="Bold" FontSize="10" Foreground="{StaticResource OkGreen}"/>
                    <Border Canvas.Left="20" Canvas.Top="165" Width="100" Height="45" Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="1.2" CornerRadius="5">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="INSPECTION" FontSize="9" FontWeight="Black" HorizontalAlignment="Center"/>
                            <TextBlock Text="VISUAL" FontSize="7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Canvas.Left="20" Canvas.Top="215" Width="100" Height="45" Background="#F0FDF4" BorderBrush="{StaticResource OkGreen}" BorderThickness="1.2" CornerRadius="5">
                        <TextBlock Text="OUTPUT TRAY" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OkGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Canvas>

                <Polyline Points="580,200 580,275 450,275" Stroke="{StaticResource PanelBorder}" StrokeThickness="2"/>

                <Border Canvas.Left="550" Canvas.Top="140" Width="60" Height="60" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1.5" CornerRadius="8" Background="White">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🤖" FontSize="25" HorizontalAlignment="Center"/>
                        <TextBlock Text="ROBOT 2" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Canvas.Left="550" Canvas.Top="20" Width="60" Height="60" BorderBrush="{StaticResource NgRed}" BorderThickness="1.5" CornerRadius="8" Background="#FFF1F2">
                    <TextBlock Text="❌" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource NgRed}"/>
                </Border>
                <TextBlock Canvas.Left="570" Canvas.Top="85" Text="NG" FontWeight="Bold" FontSize="12" Foreground="{StaticResource NgRed}"/>

            </Canvas>
        </Viewbox>

        <StackPanel Grid.Row="1" Grid.Column="2" Margin="10,0,0,0">
            <TextBlock Text="READINGS" FontWeight="Bold" FontSize="12" Margin="0,0,0,10" Foreground="#64748B"/>
            <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,10" BorderBrush="#E2E8F0" BorderThickness="1">
                <UniformGrid Columns="2">
                    <StackPanel>
                        <TextBlock Text="Temp" FontSize="9" Foreground="Gray"/>
                        <TextBlock Text="220°C" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Press" FontSize="9" Foreground="Gray"/>
                        <TextBlock Text="45 bar" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </UniformGrid>
            </Border>
            <TextBlock Text="PRODUCTION" FontWeight="Bold" FontSize="12" Margin="0,5,0,10" Foreground="#64748B"/>
            <Border Background="White" CornerRadius="8" Padding="12" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="Total OK" FontSize="10"/>
                        <TextBlock Text="1,245" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#3B82F6"/>
                    </DockPanel>
                    <DockPanel Margin="0,5,0,0">
                        <TextBlock Text="Yield" FontSize="10"/>
                        <TextBlock Text="98.5%" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#10B981"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>