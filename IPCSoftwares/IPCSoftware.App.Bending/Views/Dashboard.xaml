                                        <TextBlock Grid.Column="1" Text="235.8 C" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="42.5" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                                <Border Padding="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ABC123004" Foreground="White" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="238.5 C" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="42.7" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top">
            <TextBlock Text="CONTROLS" FontWeight="Bold" FontSize="12" Margin="0,0,0,10" Foreground="#64748B"/>
            <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#CBD5E1" BorderThickness="1">
                <StackPanel>
                    <UniformGrid Columns="2">
                        <Button Content="START" Margin="2" Padding="5" Background="{StaticResource OkGreen}" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="PAUSE" Margin="2" Padding="5" Background="#F59E0B" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    </UniformGrid>
                    <Button Content="NEXT STAGE" Margin="2,5,2,2" Padding="5" Background="{StaticResource AccentBlue}" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </Border>
            <TextBlock Text="PROCESS FLOW" FontWeight="Bold" FontSize="12" Margin="0,5,0,5" Foreground="#64748B"/>
            <Border Background="White" CornerRadius="8" Padding="5" BorderBrush="#CBD5E1" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="5,0,5,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Module" FontWeight="Bold" FontSize="9"/>
                        <TextBlock Grid.Column="1" Text="Batch Id" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center"/>
                    </Grid>
                    <StackPanel Grid.Row="1">
                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="5,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tray Load" FontSize="8.5"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource OkGreen}" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="5,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="QR Scan / Robo Pick" FontSize="8.5"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                    <Ellipse Width="6" Height="6" Fill="Gray" Margin="1,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="5,2">
