                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FB1007" Foreground="White" Padding="5" FontWeight="Bold" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="57.80" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="72.10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="3" Text="40" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="4" Text="43" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                            </Grid>

                            <Grid Grid.Row="5" Grid.ColumnSpan="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FB1008" Foreground="White" Padding="5" FontWeight="Bold" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="60.30" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="69.50" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="3" Text="42" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="4" Text="39" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border BorderBrush="White" BorderThickness="1" Margin="2" Background="#111">
                    <StackPanel>
                        <Grid Background="{StaticResource AccentBlue}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="   BENDING UAT 3 - 4" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Padding="0,4"/>
                            <TextBlock Grid.Column="1" Text="Current Batch ID -: #BFBL01   " Foreground="White" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.RowSpan="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="Part No." Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="Temp('C)" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Padding="2"/>
                            </Border>
                            <Border Grid.Column="3" Grid.ColumnSpan="2" BorderBrush="White" BorderThickness="0,0,0,1">
                                <TextBlock Text="Force(N)" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Padding="2"/>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-3" Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-4" Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="3" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-3" Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="4" BorderBrush="White" BorderThickness="0,0,0,1">
                                <TextBlock Text="B-4" Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="5">
                                <Grid Background="#1a1a1a">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB1001" Foreground="White" Padding="5" FontWeight="Bold" FontSize="10"/>
                                    <TextBlock Grid.Column="1" Text="59.10" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="72.30" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="45" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="47" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB1002" Foreground="White" Padding="5" FontWeight="Bold" FontSize="10"/>
                                    <TextBlock Grid.Column="1" Text="57.60" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="70.40" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="47" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="52" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <Grid Background="#1a1a1a">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB1003" Foreground="White" Padding="5" FontWeight="Bold" FontSize="10"/>
                                    <TextBlock Grid.Column="1" Text="59.90" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="68.10" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="42" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="45" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB1004" Foreground="White" Padding="5" FontWeight="Bold" FontSize="10"/>
                                    <TextBlock Grid.Column="1" Text="61.20" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="72.50" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="38" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="35" Foreground="White" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>




        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top">
            <TextBlock Text="CONTROLS" FontWeight="Bold" FontSize="12" Margin="0,0,0,10" Foreground="#64748B"/>
            <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#CBD5E1" BorderThickness="1">
                <StackPanel>
                    <UniformGrid Columns="2">
                        <Button Margin="2" Padding="5" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <TextBlock Text="AUTO RUN" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Margin="2" Padding="5" Background="#64748B" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <TextBlock Text="DRY RUN" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,5,0,0">
                        <Button Margin="2" Padding="5" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <TextBlock Text="CYCLE START/STOP" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Margin="2" Padding="5" Background="#6366F1" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <TextBlock Text="WORK PAYOUT START" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                    </UniformGrid>

                    <Button Margin="2,5,2,2" Padding="10" Background="#F59E0B" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <TextBlock Text="MASS RETURN TO ORIGIN" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top">
                <TextBlock Text="PROCESS FLOW" FontWeight="Bold" FontSize="12" Margin="0,0,0,10" Foreground="#64748B"/>

                <Border BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Background="#111827" ClipToBounds="True" Height="180">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#1E293B" Padding="8,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="STATUS" Foreground="White" FontWeight="Bold" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="BATCH ID" Foreground="White" FontWeight="Bold" FontSize="10" Margin="0,0,15,0"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8,5">
                                <TextBlock Text="MODULES" Foreground="#FFB74D" FontWeight="Bold" FontSize="10" Margin="0,0,0,8"/>

                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Tray/Load" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL010" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="QR/Scan-Pickup" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL009" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Pre-Bend Inspection" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL008" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Load Jig-(TT-1)" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL007" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Bending-UAT1 -2" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL006" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Transfer TT1 to TT2" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL005" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Bending-UAT3-4" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL004" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Film Teiring" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL003" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Final Inspection St-3" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL002" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>

                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Output Tray Unload" Foreground="White" FontSize="10.5"/>
                                        <TextBlock Grid.Column="1" Text="#BFBL001" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </StackPanel>



        </StackPanel>

        <Viewbox Grid.Row="2" Grid.Column="1" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
            <Canvas Width="847" Height="480">
                <Polyline Points="25,310 40,385 170,385" Stroke="{StaticResource PanelBorder}" StrokeThickness="2.5" HorizontalAlignment="Left" Canvas.Top="10" VerticalAlignment="Center" Canvas.Left="79"/>
                <Polyline Points="595,310 580,385 455,385" Stroke="{StaticResource PanelBorder}" StrokeThickness="2.5" Canvas.Top="10" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="166"/>


                <StackPanel Orientation="Horizontal" Canvas.Left="10" Canvas.Top="10" HorizontalAlignment="Left" VerticalAlignment="Center" Width="850" RenderTransformOrigin="0.501,0.596">

                    <Border Width="190" CornerRadius="5" Background="{StaticResource TableBg}" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1.5" Margin="0,0,15,0">
                        <StackPanel>
                            <Border Background="{StaticResource AccentBlue}" Padding="6,3">
                                <TextBlock Text="Bending UAT - 1" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Left"/>
                            </Border>
                            <Grid Margin="10,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="CLAMP" Foreground="White" FontSize="9" VerticalAlignment="Center" Margin="0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Completed" Foreground="{StaticResource OkGreen}" FontSize="8.5" VerticalAlignment="Center" TextAlignment="Right" Margin="5,0"/>
                                <Ellipse Grid.Row="0" Grid.Column="2" Width="9" Height="9" Fill="{StaticResource OkGreen}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="PUNCH" Foreground="White" FontSize="9" VerticalAlignment="Center" Margin="0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Incomplete" Foreground="{StaticResource NgRed}" FontSize="8.5" VerticalAlignment="Center" TextAlignment="Right" Margin="5,0"/>
                                <Ellipse Grid.Row="1" Grid.Column="2" Width="9" Height="9" Fill="{StaticResource NgRed}" VerticalAlignment="Center" Margin="5,0,0,0"/>
