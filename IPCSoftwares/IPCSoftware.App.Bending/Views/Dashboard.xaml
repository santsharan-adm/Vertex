                                        <TextBlock Grid.Column="1" Text="233.4 C" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="42.4" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>
                                    </Grid>
