                                <Border Background="{StaticResource RowEvenBg}" Padding="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ABC123001" Foreground="White" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="230.6 C" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="42.2" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                                <Border Padding="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ABC123002" Foreground="White" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="233.4 C" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="42.4" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
