                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="FLEX BENDING MACHINE" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource OkGreen}" Margin="20,0,0,0" Padding="8,2" CornerRadius="4" VerticalAlignment="Center">
                        <TextBlock Text="RUNNING" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="CYCLE TIME: 12.4s" Foreground="White" FontWeight="Bold" Margin="0,0,20,0"/>
                    <TextBlock Text="EFFICIENCY: 94%" Foreground="{StaticResource OkGreen}" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Background="#1E293B" CornerRadius="8" Padding="5" Margin="0,0,0,15" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1.5">
            <UniformGrid Columns="2">

                <Border BorderBrush="White" BorderThickness="1" Margin="2" Background="#111">
                    <StackPanel>
                        <Grid Background="{StaticResource AccentBlue}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="   BENDING UAT 1 - 2" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Padding="0,4"/>
