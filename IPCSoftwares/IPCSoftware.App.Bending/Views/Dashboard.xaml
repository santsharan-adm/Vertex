                    </StackPanel>
                </Border>
                <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" Margin="5" Padding="0" CornerRadius="5" Background="{StaticResource TableBg}" ClipToBounds="True">
                    <StackPanel>
                        <Border Background="{StaticResource AccentBlue}" Padding="8,4">
