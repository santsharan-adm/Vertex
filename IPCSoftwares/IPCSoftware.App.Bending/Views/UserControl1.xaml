                    <Style x:Key="RoboArmMainStyle" TargetType="Path">
                        <Setter Property="Stroke" Value="{StaticResource PanelBorder}"/>
                        <Setter Property="StrokeThickness" Value="9"/>
                        <Setter Property="StrokeLineJoin" Value="Round"/>
