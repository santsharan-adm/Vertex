<UserControl x:Class="IPCSoftware.App.Bending.Views.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1672" Background="#F1F5F9">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBorder" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="OkGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="NgRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="TableBg" Color="#0F172A"/>
        <SolidColorBrush x:Key="RowEvenBg" Color="#1E293B"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <!--Controls-->
        <Border Grid.Row="0" Grid.Column="0" Background="#1E293B" CornerRadius="8" Padding="3" Margin="0" >

            <StackPanel  Margin="0" VerticalAlignment="Top" Width="280">

                <Border Background="{StaticResource AccentBlue}" CornerRadius="5" Margin="10">
                    <TextBlock Text="CONTROLS" FontWeight="Bold" FontSize="12" Foreground="White" Padding="8,1"/>
                </Border>
                <Border Background="{StaticResource TableBg}" CornerRadius="8" Padding="10" BorderBrush="#CBD5E1" BorderThickness="1" Height="137">
                    <StackPanel>

                        <Button Margin="2" Padding="5" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="AUTO RUN" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Margin="2" Padding="5" Background="#64748B" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="DRY RUN" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>



                        <Button Margin="2" Padding="5" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="CYCLE START/STOP" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Margin="2" Padding="5" Background="#6366F1" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="WORK PAYOUT START" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>






                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!--PROCESS FLOW-->
        <Grid Grid.Row="1" Grid.Column="0" Margin="3" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Content="Go To Menu"
                    Margin="0"
                    Padding="3"
                    Background="#6366F1"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Border Grid.Row="1" Background="{StaticResource AccentBlue}" CornerRadius="5" Margin="3">
                <TextBlock Text="PROCESS FLOW" FontWeight="Bold" FontSize="12" Padding="3" Foreground="White"/>
            </Border>

            <Border Grid.Row="2" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" CornerRadius="8" Background="#111827" Margin="3" ClipToBounds="True" >
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource TableBg}"  Padding="8,5">
                        <Grid Background="{StaticResource TableBg}" >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="STATUS" Foreground="White" FontWeight="Bold" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="BATCH No." Foreground="White" FontWeight="Bold" FontSize="10" Margin="0,0,15,0"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tray/Load" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL010" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="QR/Scan-Pickup" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL009" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Pre-Bend Inspection" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL008" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Load Jig-(TT-1)" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL007" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bending-UAT1 -2" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL006" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Transfer TT1 to TT2" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL005" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bending-UAT3-4" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL004" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Film Teiring" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL003" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Final Inspection St-3" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL002" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>

                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Output Tray Unload" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL001" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>


            <!-- EFFICIENCY BREAKDOWN -->
            <Border Grid.Row="3" Background="#1E293B" CornerRadius="8" Padding="8">
                <StackPanel>
                    <TextBlock Text="EFFICIENCY BREAKDOWN" Foreground="White" FontWeight="Bold" FontSize="11" Padding="0,0,0,8"/>

                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Availability" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#334155"/>
                            <Border CornerRadius="4" Background="#10B981" HorizontalAlignment="Left" Width="96"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="96%" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Performance" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#334155"/>
                            <Border CornerRadius="4" Background="#3B82F6" HorizontalAlignment="Left" Width="91"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="91%" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Quality" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#334155"/>
                            <Border CornerRadius="4" Background="#F59E0B" HorizontalAlignment="Left" Width="97"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="97%" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OEE Details" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#334155"/>
                            <Border CornerRadius="4" Background="#3B82F6" HorizontalAlignment="Left" Width="91"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="91%" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>


                    <Border Height="1" Background="#334155" Padding="0"/>

                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="4" Background="#064E3B" Padding="6,2">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center"/>
                                <TextBlock Text="  OK : 156" Foreground="#10B981" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="4" Background="#450A0A" Padding="6,2">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center"/>
                                <TextBlock Text="  NG : 4" Foreground="#EF4444" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </Grid>

        <!--Bending 1,2,3,4-->
        <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="#1E293B" CornerRadius="8" Padding="5" Margin="0" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1.5">
            <UniformGrid Columns="4">

                <!--Input Inspection-->
                <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" CornerRadius="8" Background="{StaticResource TableBg}" ClipToBounds="True">
                    <StackPanel>
                        <Grid Background="{StaticResource AccentBlue}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="INPUT INSPECTION" Foreground="White" FontWeight="Bold" FontSize="11" Padding="8,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Batch No. -: #BFBL02" Foreground="White" FontWeight="Bold" FontSize="10" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="65"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.RowSpan="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="Part No." Foreground="White" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="Measurement" Foreground="White" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.RowSpan="2" Grid.Column="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="Result" Foreground="White" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Row="1" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border BorderBrush="White" BorderThickness="0,0,1,1">
                                    <TextBlock Text="X" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="1" BorderBrush="White" BorderThickness="0,0,1,1">
                                    <TextBlock Text="Y" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                    <TextBlock Text="Z" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="3" BorderBrush="White" BorderThickness="0,0,1,1">
                                    <TextBlock Text="θ" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                                <Grid Background="#1a1a1a" Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10.028"/>
                                        <ColumnDefinition Width="3.111"/>
                                        <ColumnDefinition Width="51.861"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB1000005" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                    <TextBlock Grid.Column="1" Text="34.6" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="56.7" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="10.3" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="45.6" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="7" Text="OK" Foreground="{StaticResource OkGreen}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>

                                <Grid Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="65"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB1006" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,5,0" Height="14"/>
                                    <TextBlock Grid.Column="2" Text="34.5" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Height="14" Width="20"/>
                                    <TextBlock Grid.Column="3" Text="56.7" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Height="14" Width="19" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="10.3" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Height="14" Width="18" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="5" Text="45.6" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Height="14" Width="19" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="6" Text="OK" Foreground="{StaticResource OkGreen}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Height="14" Width="14"/>
                                </Grid>

                                <Grid Background="#1a1a1a" Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="65"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB1007" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                    <TextBlock Grid.Column="1" Text="34.5" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="56.7" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="10.3" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="45.6" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="5" Text="OK" Foreground="{StaticResource OkGreen}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Height="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="65"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB1008" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                    <TextBlock Grid.Column="1" Text="33.1" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="56.7" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="10.3" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="45.6" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="5" Text="NG" Foreground="{StaticResource NgRed}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <!--BENDING UAT 1 - 2-->
                <Border BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" Margin="2" CornerRadius="8" Background="{StaticResource TableBg}">
                    <StackPanel>
                        <Grid Background="{StaticResource AccentBlue}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="   BENDING UAT 1 - 2" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Padding="0,4" Margin="-2,0,2,0"/>
                            <TextBlock Grid.Column="1" Text="Batch No. -: #BFBL02   " Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.RowSpan="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="Part No." Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="Temp('C)(50 - 60)" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Padding="2"/>
                            </Border>
                            <Border Grid.Column="3" Grid.ColumnSpan="2" BorderBrush="White" BorderThickness="0,0,0,1">
                                <TextBlock Text="Force(N)(5 - 10)" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Padding="2"/>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-1" Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-2" Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="3" BorderBrush="White" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-1" Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="4" BorderBrush="White" BorderThickness="0,0,0,1">
                                <TextBlock Text="B-2" Foreground="White" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Row="2" Grid.ColumnSpan="5" Background="#1a1a1a">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FB1005" Foreground="White" Padding="5" FontWeight="Bold" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="62.15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="71.40" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="3" Text="41" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="4" Text="44" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                            </Grid>

                            <Grid Grid.Row="3" Grid.ColumnSpan="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
