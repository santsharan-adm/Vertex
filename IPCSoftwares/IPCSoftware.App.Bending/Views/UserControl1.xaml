<UserControl x:Class="IPCSoftware.App.Bending.Views.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1672" Background="#F1F5F9">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBorder" Color="#1E293B"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="OkGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="NgRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="TableBg" Color="#0F172A"/>
        <SolidColorBrush x:Key="RowEvenBg" Color="#1E293B"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <!--Controls-->
        <Border Grid.Row="0" Grid.Column="0" CornerRadius="8" Margin="3" Width="150" HorizontalAlignment="Left"
                BorderBrush="{StaticResource AccentBlue}" BorderThickness="2" Background="#1A2540">
            <StackPanel>
                <Border Background="{StaticResource AccentBlue}" CornerRadius="6,6,0,0" Padding="6,5">
                    <TextBlock Text="CONTROLS" FontWeight="Bold" FontSize="11" Foreground="White" HorizontalAlignment="Center"/>
                </Border>
                <StackPanel Margin="6,6,6,8">
                    <Button Margin="0,3" Padding="3,6" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" FontSize="10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="AUTO RUN" TextAlignment="Center"/>
                    </Button>
                    <Button Margin="0,3" Padding="3,6" Background="#64748B" Foreground="White" FontWeight="Bold" BorderThickness="0" FontSize="10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="DRY RUN" TextAlignment="Center"/>
                    </Button>
                    <Button Margin="0,3" Padding="3,6" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" FontSize="10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="CYCLE START/STOP" TextAlignment="Center"/>
                    </Button>
                    <Button Margin="0,3" Padding="3,6" Background="#6366F1" Foreground="White" FontWeight="Bold" BorderThickness="0" FontSize="10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="WORK PAYOUT START" TextAlignment="Center"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!--PROCESS FLOW-->
        <Grid Grid.Row="1" Grid.Column="0" Margin="3" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Content="Go To Menu"
                    Margin="0,0,89,3"
                    Padding="3"
                    Width="150"
                    Background="#6366F1"
                    Foreground="White"
                    FontWeight="Bold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Border Grid.Row="1" Grid.RowSpan="2" CornerRadius="8" Margin="0,0,0,3"
                    BorderBrush="{StaticResource AccentBlue}" BorderThickness="2" Background="#1A2540">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource AccentBlue}" CornerRadius="6,6,0,0" Padding="6,5">
                        <TextBlock Text="PROCESS FLOW" FontWeight="Bold" FontSize="11" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="6,6,6,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="STATUS" Foreground="White" FontWeight="Bold" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="BATCH No." Foreground="White" FontWeight="Bold" FontSize="10"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="6,0,6,6">
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tray/Load" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL010" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="QR/Scan-Pickup" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL009" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Pre-Bend Inspection" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL008" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Load Jig-(TT-1)" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL007" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bending-UAT1 -2" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL006" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Transfer TT1 to TT2" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL005" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bending-UAT3-4" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL004" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Film Teiring" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL003" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Final Inspection St-3" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL002" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Output Tray Unload" Foreground="White" FontSize="10.5"/>
                                <TextBlock Grid.Column="1" Text="#BFBL001" Foreground="White" FontSize="10.5" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>


            <!-- EFFICIENCY BREAKDOWN -->
            <Border Grid.Row="3" Background="#1E293B" CornerRadius="8" Padding="8">
                <StackPanel>
                    <TextBlock Text="EFFICIENCY BREAKDOWN" Foreground="White" FontWeight="Bold" FontSize="11" Padding="0,0,0,8"/>

                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Availability" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#334155"/>
                            <Border CornerRadius="4" Background="#10B981" HorizontalAlignment="Left" Width="96"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="96%" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Performance" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#334155"/>
                            <Border CornerRadius="4" Background="#3B82F6" HorizontalAlignment="Left" Width="91"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="91%" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Quality" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#334155"/>
                            <Border CornerRadius="4" Background="#F59E0B" HorizontalAlignment="Left" Width="97"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="97%" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="OEE Details" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#334155"/>
                            <Border CornerRadius="4" Background="#3B82F6" HorizontalAlignment="Left" Width="91"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="91%" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>


                    <Border Height="1" Background="#334155" Padding="0"/>

                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="4" Background="#064E3B" Padding="6,2">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center"/>
                                <TextBlock Text="  OK : 156" Foreground="#10B981" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="4" Background="#450A0A" Padding="6,2">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center"/>
                                <TextBlock Text="  NG : 4" Foreground="#EF4444" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </Grid>

        <!--Bending 1,2,3,4-->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#0B1A2E" CornerRadius="4" Padding="2" Margin="153,0,0,0" BorderBrush="#2196F3" BorderThickness="1.5">
            <UniformGrid Columns="4">

                <!--Input Inspection-->
                <Border BorderBrush="#2196F3" BorderThickness="0,0,1,0" Background="#0B1A2E" Margin="0,0,3,0">
                    <StackPanel>
                        <Grid Background="#1565C0" Height="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="INPUT INSPECTION" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0"/>
                            <TextBlock Grid.Column="1" Text="#BFBL02" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        </Grid>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="38"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.RowSpan="2" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                <TextBlock Text="Part No." Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                <TextBlock Text="Measurement" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="2"/>
                            </Border>
                            <Border Grid.RowSpan="2" Grid.Column="2" BorderBrush="#2196F3" BorderThickness="0,0,0,1">
                                <TextBlock Text="Result" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Row="1" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="28"/>
                                    <ColumnDefinition Width="*" MinWidth="28"/>
                                    <ColumnDefinition Width="*" MinWidth="28"/>
                                    <ColumnDefinition Width="*" MinWidth="28"/>
                                </Grid.ColumnDefinitions>
                                <Border BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                    <TextBlock Text="X" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="1" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                    <TextBlock Text="Y" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                    <TextBlock Text="Z" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="3" BorderBrush="#2196F3" BorderThickness="0,0,0,1">
                                    <TextBlock Text="θ" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                <Grid Background="#0D2137" Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB100000000000000005" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="34.60" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="56.70" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="10.30" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="45.60" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Grid>

                                <Grid Background="#0B1A2E" Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB100000000000000006" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="34.50" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="56.70" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="10.30" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="45.60" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Grid>

                                <Grid Background="#0D2137" Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB100000000000000007" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="34.50" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="56.70" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="10.30" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="45.60" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Grid>

                                <Grid Background="#0B1A2E" Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                        <ColumnDefinition Width="*" MinWidth="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="FB100000000000000008" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="33.10" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="56.70" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="3" Text="10.30" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="4" Text="45.60" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <Border Height="30" Background="#0D2137">
                                    <TextBlock Text="OK" Foreground="{StaticResource OkGreen}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Height="30" Background="#0B1A2E">
                                    <TextBlock Text="OK" Foreground="{StaticResource OkGreen}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Height="30" Background="#0D2137">
                                    <TextBlock Text="OK" Foreground="{StaticResource OkGreen}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Height="30" Background="#0B1A2E">
                                    <TextBlock Text="NG" Foreground="{StaticResource NgRed}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!--BENDING UAT 1 - 2-->
                <Border BorderBrush="#2196F3" BorderThickness="0,0,1,0" Background="#0B1A2E" Margin="3,0">
                    <StackPanel>
                        <Grid Background="#1565C0" Height="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="BENDING UAT 1 - 2" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0"/>
                            <TextBlock Grid.Column="1" Text="#BFBL02" Foreground="White" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        </Grid>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.RowSpan="2" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                <TextBlock Text="Part No." Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                <TextBlock Text="Temp (°C)" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="2"/>
                            </Border>
                            <Border Grid.Column="3" Grid.ColumnSpan="2" BorderBrush="#2196F3" BorderThickness="0,0,0,1">
                                <TextBlock Text="Force (N)" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="2"/>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-1" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-2" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="3" BorderBrush="#2196F3" BorderThickness="0,0,1,1">
                                <TextBlock Text="B-1" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="4" BorderBrush="#2196F3" BorderThickness="0,0,0,1">
                                <TextBlock Text="B-2" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="5">
                                <Grid Background="#0D2137" Height="30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
