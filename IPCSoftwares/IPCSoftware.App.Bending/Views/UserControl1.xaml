                    </Style>




                    <GeometryGroup x:Key="Arm2Geometry">
                        <PathGeometry Figures="M 730,342 L 690,342 L 648,412"/>
                        <EllipseGeometry Center="690,342" RadiusX="6" RadiusY="6"/>
                    </GeometryGroup>
                </Canvas.Resources>
                <Canvas.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <!--
                                    One full cycle = 4 steps, each step:
                                      TT1 rotates +90° over 0.8s, holds 0.4s
                                      TT2 rotates +120° over 0.8s, holds 0.4s
                                    Step duration = 2.4s  ×  4 steps = 9.6s total
                                -->

                                <!-- TT1: 0→90 at t=0..0.8, hold; 90→180 at t=2.4..3.2; 180→270 at t=4.8..5.6; 270→360 at t=7.2..8.0 -->
                                <DoubleAnimationUsingKeyFrames
                                    Storyboard.TargetName="TT1RotateTransform"
                                    Storyboard.TargetProperty="Angle">
                                    <!-- Step 1: TT1 moves -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                                    <LinearDoubleKeyFrame   KeyTime="0:0:0.8" Value="90"/>
                                    <!-- hold while TT2 moves (0.4s hold + 0.8s TT2 move + 0.4s TT2 hold = 1.6s) -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:2.4"  Value="90"/>
                                    <!-- Step 2: TT1 moves -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:3.2" Value="180"/>
                                    <!-- hold -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:4.8"  Value="180"/>
                                    <!-- Step 3: TT1 moves -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:5.6" Value="270"/>
                                    <!-- hold -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:7.2"  Value="270"/>
                                    <!-- Step 4: TT1 moves -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:8.0" Value="360"/>
                                    <!-- hold until cycle end -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:9.6"  Value="360"/>
                                </DoubleAnimationUsingKeyFrames>

                                <!-- TT2: moves after each TT1 step (offset by 1.2s), +120° each time -->
                                <DoubleAnimationUsingKeyFrames
    Storyboard.TargetName="TT2RotateTransform"
    Storyboard.TargetProperty="Angle">
                                    <!-- hold while TT1 does step 1 (0→0.8s move + 0.4s hold = 1.2s) -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0"    Value="0"/>
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:1.2"  Value="0"/>
                                    <!-- Step 1: TT2 moves -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:2.0" Value="120"/>
                                    <!-- hold while TT1 does step 2 -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3.6"  Value="120"/>
                                    <!-- Step 2: TT2 moves -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:4.4" Value="240"/>
                                    <!-- hold while TT1 does step 3 -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:6.0"  Value="240"/>
                                    <!-- Step 3: TT2 moves -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:6.8" Value="360"/>
                                    <!-- hold while TT1 does step 4 -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:8.4"  Value="360"/>
                                    <!-- Step 4: TT2 moves (wraps back for next cycle) -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:9.2" Value="480"/>
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:9.6"  Value="480"/>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>

                    <!-- Arm 1 tip animation: Input Tray → Inspection → TT1 → Input Tray -->
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimationUsingKeyFrames
                                    Storyboard.TargetName="Arm1Lower"
                                    Storyboard.TargetProperty="X2">
                                    <!-- t=0: at Input Tray -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0"  Value="155"/>
                                    <!-- t=2: arrive Inspection Unit -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:2"  Value="175"/>
                                    <!-- t=3: hold 1s at Inspection -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3"  Value="175"/>
                                    <!-- t=5: arrive TT1 -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:5"  Value="195"/>
                                    <!-- t=7: hold 2s at TT1 -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:7"  Value="195"/>
                                    <!-- t=9: return to Input Tray -->
                                    <LinearDoubleKeyFrame   KeyTime="0:0:9"  Value="155"/>
                                    <!-- t=11: hold 2s at Input Tray before repeat -->
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:11" Value="155"/>
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames
                                    Storyboard.TargetName="Arm1Lower"
                                    Storyboard.TargetProperty="Y2">
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:0"  Value="370"/>
                                    <LinearDoubleKeyFrame   KeyTime="0:0:2"  Value="335"/>
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:3"  Value="335"/>
                                    <LinearDoubleKeyFrame   KeyTime="0:0:5"  Value="260"/>
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:7"  Value="260"/>
                                    <LinearDoubleKeyFrame   KeyTime="0:0:9"  Value="370"/>
                                    <DiscreteDoubleKeyFrame KeyTime="0:0:11" Value="370"/>
