                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Action" Width="200">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <Button Content="WRITE"
                                        Command="{Binding DataContext.WriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="#007ACC"
                                        Foreground="White"
                                        FontSize="20"
                                        FontWeight="Bold"
                                        Height="50"
                                        Width="140"/>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>